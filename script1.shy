#!/bin/bash
# Script 1: System Identity Report

STUDENT_NAME="Shreya Gupta"
SOFTWARE_CHOICE="Git"

KERNEL=$(uname -r)
USER_NAME=$(whoami)
UPTIME=$(uptime -p)
DATE=$(date)

echo "================================"
echo " Open Source Audit — $STUDENT_NAME"
echo "================================"
echo "Software: $SOFTWARE_CHOICE"
echo "User: $USER_NAME"
echo "Kernel: $KERNEL"
echo "Uptime: $UPTIME"
echo "Date: $DATE"
echo "License: GNU/Linux is based on GPL license"
